# Neon Postgres (from Vercel Marketplace or neon.tech)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Clerk Auth (from clerk.com or Vercel Marketplace)
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Email domain allowlist (comma-separated, controls who can access the app)
ALLOWED_EMAIL_DOMAINS=centific.com,oneforma.com

# OpenRouter API (for Kimi K2.5 channel research + RFP extraction)
OPENROUTER_API_KEY=sk-or-...

# Vercel Blob (from Vercel dashboard)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Microsoft Teams Incoming Webhook
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# App URL (for notification links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Reddit Ads (Wave 1 — May 6)
REDDIT_ADS_ACCESS_TOKEN=
REDDIT_ADS_AD_ACCOUNT_ID=

# Brevo email marketing (Wave 1 — May 6)
BREVO_API_KEY=

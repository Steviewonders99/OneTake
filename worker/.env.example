# Neon Postgres (same connection string as frontend)
DATABASE_URL=postgresql://user:pass@ep-xxx.eastus2.azure.neon.tech/neondb?sslmode=require

# OpenRouter API (for image generation via Seedream + any cloud LLM fallbacks)
OPENROUTER_API_KEY=sk-or-v1-...

# Vercel Blob (for uploading generated images)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Microsoft Teams Webhook (pending tenant access)
TEAMS_WEBHOOK_URL=

# App URL (for links in notifications)
APP_URL=https://your-app.vercel.app

# Polling interval (seconds)
POLL_INTERVAL_SECONDS=30

# Image model (via OpenRouter)
IMAGE_MODEL=doubao/seedream-4-5
